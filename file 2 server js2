// Handle Form
app.post("/submit", (req, res) => {
  const { kiasi, siri } = req.body;

  submissions.push({
    kiasi,
    siri,
    date: new Date().toLocaleString()
  });

  res.send(`
    <h2>Asante! Taarifa zimepokelewa.</h2>
    <a href="/admin">View Admin</a><br/><br/>
    <a href="/">Rudi Nyumbani</a>
  `);
});

// Admin Page
app.get("/admin", (req, res) => {
  let html = `
    <h2>Submitted Entries</h2>
    <table border="1" cellpadding="10" cellspacing="0">
      <tr>
        <th>Kiasi Cha Zawadi</th>
        <th>Neno La Siri</th>
        <th>Date</th>
      </tr>
  `;

  submissions.forEach(entry => {
    html += `
      <tr>
        <td>${entry.kiasi}</td>
        <td>${entry.siri}</td>
        <td>${entry.date}</td>
      </tr>
    `;
  });

  html += `</table><br><a href="/">Back Home</a>`;

  res.send(html);
});

app.listen(PORT, () => {
